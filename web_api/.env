############################
# PAESE_PDF_API args       #
############################
PARSE_PDF_API_HOST = "http://mineru:8000/pdf_parse"

# Parse PDF API output dir
PARSE_PDF_API_OUTPUT_DIR=~/plugin-data-tmp

# NOTE: 目前 mineru 的 paddleocr cpu/gpu模式要使用不同的docker image
# PARSE_PDF_API_IMAGE=t300/mineru:0.8.1-paddle-cpu-20250528-01
PARSE_PDF_API_IMAGE=t300/mineru:0.8.1-paddle-gpu-20250717-01
#CONVERTER_MODE=cpu
CONVERTER_MODE=cuda

CONVERTER_CUDA_VISIBLE_DEVICES=2
# 這裡要換成 nvidia/ runc
#CONVERTER_RUNTIME=runc
CONVERTER_RUNTIME=nvidia

# VRAM monitor (MB)
VRAM_MAX_MB=78000
